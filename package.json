{
  "name": "keking",
  "version": "1.0.0",
  "description": "Discord bot boilerplate with discord.js and TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "pnpm build",
    "start": "node --enable-source-maps dist/index.js",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "deploy:clear-commands": "tsx src/clear-commands.ts",
    "docker:build": "docker build -t keking-bot .",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f bot",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@discord-player/extractor": "^7.2.0",
    "@discordjs/voice": "^0.19.2",
    "axios": "^1.16.1",
    "discord-player": "^7.2.0",
    "discord-player-tts": "^1.0.9",
    "discord-player-youtube": "^0.8.4",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "ffmpeg-static": "^5.3.0",
    "genius-lyrics": "^4.4.7",
    "libsodium-wrappers": "^0.8.4",
    "pg": "^8.20.0",
    "youtube-dl-exec": "^3.1.5"
  }
}
